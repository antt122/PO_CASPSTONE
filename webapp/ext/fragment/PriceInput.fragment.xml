<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <VBox id="idCustomPriceVBox">
        
        <Text id="idCustomPriceText" 
              text="{NetPrice}" 
              visible="{= !${ui>/isEditable} }" />
        
        <Input id="idCustomPriceInput" 
               value="{NetPrice}" 
               visible="{ui>/isEditable}" />
               
    </VBox>
</core:FragmentDefinition>