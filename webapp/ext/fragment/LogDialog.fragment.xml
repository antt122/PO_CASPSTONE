<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="idMyLogDlg" title="PO Change History" contentWidth="1050px" contentHeight="450px" resizable="true" draggable="true">
        <content>
            <Table id="jobLogTable" items="{path: '/PoChangeLog'}" noDataText="No Change History Record For This PO." alternateRowColors="true">
                <columns>
                    <Column id="colTime" width="160px">
                        <Text id="lblTime" text="Changed At" />
                    </Column>
                    <Column id="colUser" width="120px">
                        <Text id="lblUser" text="Changed By" />
                    </Column>
                    <Column id="colField" width="150px">
                        <Text id="lblField" text="Field Name" />
                    </Column>
                    <Column id="colOldValue">
                        <Text id="lblOldValue" text="Old Value" />
                    </Column>
                    <Column id="colNewValue">
                        <Text id="lblNewValue" text="New Value" />
                    </Column>
                    
                    <Column id="colReason">
                        <Text id="lblReason" text="Reason" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem id="cliLogItem">
                        <cells>
                            <Text id="txtChangedAt" text="{ChangedAt}"/>
                            <Text id="txtChangedBy" text="{ChangedBy}"/>
                            <Text id="txtFieldName" text="{FieldName}"/>
                            <Text id="txtOldValue" text="{OldValue}"/>
                            <Text id="txtNewValue" text="{NewValue}"/>
                            
                            <ExpandableText id="txtChangeReason" 
                                            text="{ChangeReason}" 
                                            maxCharacters="30" 
                                            overflowMode="Popover" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <buttons>
            <Button id="btnCloseLog" text="Close" press=".onCloseLogDialog" type="Reject"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>