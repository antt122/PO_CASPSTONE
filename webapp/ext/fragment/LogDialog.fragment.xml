<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="idMyLogDlg" title="PO Change History" contentWidth="1000px" contentHeight="450px" resizable="true" draggable="true">
        <content>
            <Table id="jobLogTable" items="{path: '/PoChangeLog'}" noDataText="No Change History Record For This PO." alternateRowColors="true">
                <columns>
                    <Column id="colPoNumber" width="120px"><Text id="lblPoNumber" text="PO Number" /></Column>
                    
                    <Column id="colTime" width="180px"><Text id="lblTime" text="Changed At" /></Column>
                    <Column id="colUser" width="120px"><Text id="lblUser" text="Changed By" /></Column>
                    <Column id="colReason"><Text id="lblReason" text="Change Reason" /></Column>
                </columns>
                <items>
                    <ColumnListItem id="cliLogItem">
                        <cells>
                            <Text id="txtPoNumber" text="{PoNumber}"/>
                            
                            <Text id="txtChangedAt" text="{ChangedAt}"/>
                            <Text id="txtChangedBy" text="{ChangedBy}"/>
                            <Text id="txtChangeReason" text="{ChangeReason}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <buttons>
            <Button id="btnCloseLog" text="Close" press=".onCloseLogDialog" type="Reject"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>