<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx" Version="4.0">
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
        <edmx:Include Namespace="com.sap.vocabularies.Common.v1" Alias="Common"/>
    </edmx:Reference>
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Capabilities.xml">
        <edmx:Include Namespace="Org.OData.Capabilities.V1" Alias="Capabilities"/>
    </edmx:Reference>
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/UI.xml">
        <edmx:Include Namespace="com.sap.vocabularies.UI.v1" Alias="UI"/>
    </edmx:Reference>
    <edmx:Reference Uri="/sap/opu/odata4/iwbep/all/srvd/sap/zui_purchaseorder/0001/$metadata">
        <edmx:Include Namespace="com.sap.gateway.srvd.zui_purchaseorder.v0001" Alias="SAP__self"/>
    </edmx:Reference>
    <edmx:DataServices>
        <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="local_general">
            <Annotations Target="SAP__self.PurchaseOrderType">
                <Annotation Term="UI.DeleteHidden" Bool="true"/>
<Annotation Term="UI.UpdateHidden">
        <If>
            <Or>
                <Eq>
                    <Path>ReleaseCode</Path>
                    <String>G</String>
                </Eq>
                <Eq>
                    <Path>ReleaseCode</Path>
                    <String>R</String>
                </Eq>
            </Or>
            <Bool>true</Bool>   <Bool>false</Bool>  </If>
    </Annotation>
                <!-- ============================================================ -->
                <!-- HEADER INFO                                                  -->
                <!-- ============================================================ -->
                <Annotation Term="UI.HeaderInfo">
                    <Record Type="UI.HeaderInfoType">
                        <PropertyValue Property="TypeName" String="Purchase Order"/>
                        <PropertyValue Property="TypeNamePlural" String="Purchase Orders"/>
                        <PropertyValue Property="Title">
                            <Record Type="UI.DataField">
                                <PropertyValue Property="Value" Path="PoNumber"/>
                            </Record>
                        </PropertyValue>
                        <PropertyValue Property="Description">
                            <Record Type="UI.DataField">
                                <PropertyValue Property="Value" Path="Supplier"/>
                            </Record>
                        </PropertyValue>
                    </Record>
                </Annotation>


                <Annotation Term="UI.PresentationVariant">
                    <Record Type="UI.PresentationVariantType">
                        <PropertyValue Property="SortOrder">
                            <Collection>
                                <Record Type="Common.SortOrderType">
                                    <PropertyValue Property="Property" PropertyPath="LocalLastChangedAt"/>
                                    <PropertyValue Property="Descending" Bool="true"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>


                <Annotation Term="Capabilities.SearchRestrictions">
                    <Record>
                        <PropertyValue Property="Searchable" Bool="true"/>
                    </Record>
                </Annotation>

                <!-- ============================================================ -->
                <!-- FACETS                                                       -->
                <!-- ============================================================ -->
                <Annotation Term="UI.Facets">
                    <Collection>

                        <!-- Collection: General Information (pos 10) -->
                        <Record Type="UI.CollectionFacet">
                            <PropertyValue Property="ID" String="General"/>
                            <PropertyValue Property="Label" String="General Information"/>
                            <PropertyValue Property="Facets">
                                <Collection>
                                    <Record Type="UI.ReferenceFacet">
                                        <PropertyValue Property="ID" String="BasicData"/>
                                        <PropertyValue Property="Label" String="Basic Data"/>
                                        <PropertyValue Property="Target" AnnotationPath="@UI.Identification"/>
                                    </Record>
                                    <Record Type="UI.ReferenceFacet">
                                        <PropertyValue Property="ID" String="OrgData"/>
                                        <PropertyValue Property="Label" String="Organization"/>
                                        <PropertyValue Property="Target" AnnotationPath="@UI.FieldGroup#OrgGroup"/>
                                    </Record>
                                </Collection>
                            </PropertyValue>
                        </Record>

                        <!-- LineItems Reference: Po Items (pos 30) -->
                        <Record Type="UI.ReferenceFacet">
                            <PropertyValue Property="ID" String="PoItems"/>
                            <PropertyValue Property="Label" String="Line Items"/>
                            <PropertyValue Property="Target" AnnotationPath="_PoItem/@UI.LineItem"/>
                        </Record>

                        <!-- PresentationVariant Reference: Change History (pos 40) -->
                        <Record Type="UI.ReferenceFacet">
                            <PropertyValue Property="ID" String="ChangeLog"/>
                            <PropertyValue Property="Label" String="Change History"/>
                            <PropertyValue Property="Target" AnnotationPath="_PoChangeLog/@UI.PresentationVariant#SortLog"/>
                            <Annotation Term="UI.Hidden">
                                <If>
                                    <Eq>
                                        <Path>PoNumber</Path>
                                        <String></String>
                                    </Eq>
                                    <Bool>true</Bool>
                                    <Bool>false</Bool>
                                </If>
                            </Annotation>
                        </Record>

                        <!-- LineItem Reference: Attachments (pos 50) -->
                        <Record Type="UI.ReferenceFacet">
                            <PropertyValue Property="ID" String="Attachments"/>
                            <PropertyValue Property="Label" String="Attachments"/>
                            <PropertyValue Property="Target" AnnotationPath="_Attachment/@UI.LineItem"/>
                        </Record>

                        <!-- LineItem Reference: Notes (pos 60) -->
                        <Record Type="UI.ReferenceFacet">
                            <PropertyValue Property="ID" String="Notes"/>
                            <PropertyValue Property="Label" String="Notes"/>
                            <PropertyValue Property="Target" AnnotationPath="_PoText/@UI.LineItem"/>
                        </Record>

                    </Collection>
                </Annotation>

                <!-- ============================================================ -->
                <!-- LINE ITEM (LIST REPORT - Màn hình danh sách ngoài cùng)      -->
                <!-- ============================================================ -->
                <Annotation Term="UI.LineItem">
                    <Collection> 

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="PoNumber"/>
                            <PropertyValue Property="Label" String="PO Number"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="PoType"/>
                            <PropertyValue Property="Label" String="Type"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Medium"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="Supplier"/>
                            <PropertyValue Property="Label" String="Supplier"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="CompanyCode"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Medium"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="PurchGroup"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Low"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="PoDate"/>
                            <PropertyValue Property="Label" String="PO Date"/>
                        </Record>


                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="ReleaseCode"/>
                            <PropertyValue Property="Label" String="Release Code"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High"/>
                        </Record>
                                                <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="DeliveryDate"/>
                            <PropertyValue Property="Label" String="Delivery Date"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Medium"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="ProcessingStatus"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Low"/>
                        </Record>

                    </Collection>
                </Annotation>

                <!-- ============================================================ -->
                <!-- IDENTIFICATION (OBJECT PAGE - Màn hình Create/Edit Header)   -->
                <!-- ============================================================ -->
                <Annotation Term="UI.Identification">
                    <Collection>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="PoNumber"/>
                            <PropertyValue Property="Label" String="PO Number"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="PoType"/>
                            <PropertyValue Property="Label" String="Order Type"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="Supplier"/>
                            <PropertyValue Property="Label" String="Supplier"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="CreatedDate"/>
                            <PropertyValue Property="Label" String="Created On"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="CreatedBy"/>
                            <PropertyValue Property="Label" String="Created By"/>
                        </Record>

                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="ReleaseCode"/>
                            <PropertyValue Property="Label" String="Release Code"/>
                        </Record>
                        
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="DeliveryDate"/>
                            <PropertyValue Property="Label" String="Delivery Date (Mass Update)"/>
                            <Annotation Term="UI.Hidden" Path="IsActiveEntity"/>
                        </Record>

                    </Collection>
                </Annotation>

                <!-- ============================================================ -->
                <!-- FIELD GROUP: OrgGroup                                        -->
                <!-- ============================================================ -->
                <Annotation Term="UI.FieldGroup" Qualifier="OrgGroup">
                    <Record Type="UI.FieldGroupType">
                        <PropertyValue Property="Data">
                            <Collection>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="CompanyCode"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="PurchOrg"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="PurchGroup"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- ============================================================ -->
                <!-- SELECTION FIELDS (FILTER BAR)                                -->
                <!-- ============================================================ -->
                <Annotation Term="UI.SelectionFields">
                    <Collection>
                        <PropertyPath>PoNumber</PropertyPath>
                        <PropertyPath>PoType</PropertyPath>
                        <PropertyPath>Supplier</PropertyPath>
                        <PropertyPath>CompanyCode</PropertyPath>
                        <PropertyPath>PurchOrg</PropertyPath>
                        <PropertyPath>PurchGroup</PropertyPath>
                    </Collection>
                </Annotation>

                <!-- ============================================================ -->
                <!-- HIDDEN FIELDS                                                -->
                <!-- ============================================================ -->
                <Annotation Term="UI.Hidden" Path="LocalLastChangedAt"/>
                <Annotation Term="UI.Hidden" Path="DeletionIndicator"/>

            </Annotations>

        </Schema>
    </edmx:DataServices> 
</edmx:Edmx>